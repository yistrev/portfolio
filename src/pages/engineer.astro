---
import { SITE_NAME, GTM_ID, GTM_ENABLED, OGP_IMAGE } from '../consts';

// 各「ファイル」の中身（シンタックスハイライト済みHTML）
// ※ index.astro のコンテンツと同期させること
const aboutLines = [
  '<span class="tk-blue"># about</span>',
  '',
  '<span class="tk-bold">技術のわかるディレクター、ビジネスのわかるエンジニア。</span>',
  '',
  '単に指示された仕様通りにコードを書くプログラマーではなく、',
  '仕様書の向こう側にあるクライアントの意図や課題を紐解く',
  '<span class="tk-bold">「テクニカルディレクション」</span>の視点を大切にしています。',
  '',
  '<span class="tk-green">&gt; 仕様書の行間とコードの中身、その両方が読めるから、</span>',
  '<span class="tk-green">&gt; 「決める人」と「つくる人」のあいだで話が途切れません。</span>',
  '<span class="tk-green">&gt; プロジェクトに翻訳者を置かずに済む——二つの肩書きを名乗る理由です。</span>',
  '',
  '「つくる工程」のすべてに深く関わり、アイデアの根（ルーツ）を',
  'ビジネスの場できちんと機能する確かなシステムへと育てること。',
  'それが、この場所における物作りのスタンスです。',
  '',
  '<span class="tk-green">&gt; roots + (s)cion — 広げた興味の根から、たしかな「幹」を育てる</span>',
  '',
  '- github: <a class="tk-link" href="https://github.com/yistrev" target="_blank" rel="noopener">yistrev</a>',
];

const serviceLines = [
  '<span class="tk-comment">/** 01. ヒアリング・要件定義 — アイデアの根を紐解き、仕様へ翻訳する */</span>',
  '<span class="tk-red">export const</span> <span class="tk-purple">listen</span> = (worry: <span class="tk-orange">Worry</span>): <span class="tk-orange">Requirement</span> =&gt; clarify(worry);',
  '<span class="tk-comment">// 仕様書の向こう側にある本音を対話から汲み取り、フィジビリティを</span>',
  '<span class="tk-comment">// 考慮した破綻のない要件定義で、プロジェクトの土台を設計する。</span>',
  '',
  '<span class="tk-comment">/** 02. ディレクション・進行管理 — ビジネスと実装を境目なくつなぐ舵取り */</span>',
  '<span class="tk-red">export const</span> <span class="tk-purple">direct</span> = (req: <span class="tk-orange">Requirement</span>): <span class="tk-orange">Blueprint</span> =&gt; plan(req);',
  '<span class="tk-comment">// 立場の異なるメンバーの架け橋となり、技術的な壁打ち相手として、</span>',
  '<span class="tk-comment">// ドキュメンテーションと品質管理を徹底し公開まで並走する。</span>',
  '',
  '<span class="tk-comment">/** 03. フロントエンド実装 — 運用の先を見据えた、破綻のない構築と運用支援 */</span>',
  '<span class="tk-red">export const</span> <span class="tk-purple">build</span> = (bp: <span class="tk-orange">Blueprint</span>): <span class="tk-orange">Website</span> =&gt; implement(bp);',
  '<span class="tk-comment">// CMS設計からUI実装、サーバー移行まで一気通貫。公開後のSEO・</span>',
  '<span class="tk-comment">// セキュリティなど、持続可能な運用の環境整備まで支え続ける。</span>',
];

const skillsLines = [
  '{',
  '  <span class="tk-red">"name"</span>: <span class="tk-str">"rootscion"</span>,',
  '  <span class="tk-red">"dependencies"</span>: {',
  '    <span class="tk-comment">// markup</span>',
  '    <span class="tk-red">"html"</span>: <span class="tk-str">"living-standard"</span>,',
  '    <span class="tk-red">"css"</span>: <span class="tk-str">"sass + bem"</span>,',
  '    <span class="tk-red">"responsive"</span>: <span class="tk-str">"mobile-first"</span>,',
  '    <span class="tk-red">"a11y"</span>: <span class="tk-str">"considered"</span>,',
  '    <span class="tk-comment">// program</span>',
  '    <span class="tk-red">"javascript"</span>: <span class="tk-str">"es2024"</span>,',
  '    <span class="tk-red">"jquery"</span>: <span class="tk-str">"legacy-support"</span>,',
  '    <span class="tk-red">"gsap"</span>: <span class="tk-str">"^3.12"</span>,',
  '    <span class="tk-red">"php"</span>: <span class="tk-str">"^8"</span>,',
  '    <span class="tk-comment">// cms / framework</span>',
  '    <span class="tk-red">"wordpress"</span>: <span class="tk-str">"custom-theme"</span>,',
  '    <span class="tk-red">"tailwindcss"</span>: <span class="tk-str">"utility-first"</span>,',
  '    <span class="tk-red">"bulma"</span>: <span class="tk-str">"classic"</span>',
  '  },',
  '  <span class="tk-red">"devDependencies"</span>: {',
  '    <span class="tk-comment">// いま root を伸ばしている領域</span>',
  '    <span class="tk-red">"react-nextjs"</span>: <span class="tk-str">"learning"</span>,',
  '    <span class="tk-red">"typescript"</span>: <span class="tk-str">"learning"</span>,',
  '    <span class="tk-red">"threejs-webgl"</span>: <span class="tk-str">"learning"</span>,',
  '    <span class="tk-red">"vue-nuxt"</span>: <span class="tk-str">"learning"</span>,',
  '    <span class="tk-red">"blender"</span>: <span class="tk-str">"learning"</span>',
  '  }',
  '}',
];

const profileLines = [
  '<span class="tk-red">handle</span>: <span class="tk-str">rootscion</span>',
  '<span class="tk-red">name</span>: <span class="tk-str">YURI ISHIKAWA</span>',
  '<span class="tk-red">role</span>: <span class="tk-str">Web Engineer / Technical Director</span>',
  '<span class="tk-red">approach</span>: <span class="tk-purple">&gt;</span>',
  '  「単に動くものを作る」だけではなく、設計から実装、運用に',
  '  いたる「つくる工程と構造」のすべてに高い解像度で向き合う。',
  '  破綻のないシステム設計と、細部まで美しく機能する実装を',
  '  両立させる職人気質を軸とする。',
  '<span class="tk-red">favorites</span>: [<span class="tk-str">gadget</span>, <span class="tk-str">tactile-audio-gear</span>]',
  '<span class="tk-red">now</span>: <span class="tk-str">learning Blender</span>',
];

const worksLines = [
  '<span class="tk-green">$ git log --works</span>',
  '<span class="tk-orange">fatal:</span> まだ公開できる実績がありません',
  '',
  '<span class="tk-comment"># 実績が溜まりしだい、このログに追加されます。</span>',
  '<span class="tk-comment"># お仕事のご相談は contact.sh へ。</span>',
];

const fileMeta = [
  { id: 'about-md', name: 'about.md', dot: 'md', lang: 'Markdown' },
  { id: 'service-ts', name: 'service.ts', dot: 'ts', lang: 'TypeScript' },
  { id: 'skills-json', name: 'skills.json', dot: 'json', lang: 'JSON' },
  { id: 'profile-yml', name: 'profile.yml', dot: 'yml', lang: 'YAML' },
  { id: 'works-log', name: 'works.log', dot: 'log', lang: 'Log' },
  { id: 'contact-sh', name: 'contact.sh', dot: 'sh', lang: 'Shell Script' },
];

const pageTitle = 'rootscion OS 7 | engineer mode';
const pageDescription = 'rootscion — 仮想レトロデスクトップで閲覧するポートフォリオ（engineer mode）';
const canonical = new URL('/engineer/', Astro.site);
const ogImage = new URL(OGP_IMAGE, Astro.site);
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- OGP -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="ja_JP" />
    <meta name="twitter:card" content="summary_large_image" />

    {
      GTM_ENABLED && (
        <script is:inline define:vars={{ gtmId: GTM_ID }}>
          {`(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);})(window,document,'script','dataLayer',gtmId);`}
        </script>
      )
    }
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600;700&family=Noto+Sans+JP:wght@400;500;700&family=DotGothic16&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    {
      GTM_ENABLED && (
        <noscript>
          <iframe
            src={`https://www.googletagmanager.com/ns.html?id=${GTM_ID}`}
            height="0"
            width="0"
            style="display:none;visibility:hidden"
            title="gtm"
          />
        </noscript>
      )
    }
    <!-- menubar（System 7風・白いメニューバー） -->
    <header class="menubar">
      <div class="menubar__left">
        <img src="/favicon.svg" alt="" class="menubar__logo" />
        <strong>rootscion OS 7</strong>
        <span class="menubar__menu">File</span>
        <span class="menubar__menu">Edit</span>
        <span class="menubar__menu">View</span>
        <span class="menubar__menu">Go</span>
      </div>
      <div class="menubar__right">
        <span id="os-clock">--/-- --:--</span>
      </div>
    </header>

    <!-- desktop -->
    <main class="desktop">
      <div class="desktop__icons">
        <button class="dicon" data-open-editor>
          <span class="dicon__img" aria-hidden="true">
            <svg viewBox="0 0 44 36">
              <rect x="1" y="1" width="42" height="34" fill="#fffffe" stroke="#001e1d" stroke-width="2" />
              <path d="M1 11h42" stroke="#001e1d" stroke-width="2" />
              <path d="M12 4.2h28M12 6.7h28M12 9.2h28" stroke="#001e1d" stroke-width="1" />
              <rect x="3.5" y="3.5" width="5" height="5" fill="#fffffe" stroke="#001e1d" stroke-width="1.4" />
              <rect x="7" y="16" width="14" height="3" fill="#6246ea" />
              <rect x="7" y="22" width="22" height="3" fill="#0a7489" />
              <rect x="12" y="28" width="16" height="3" fill="#00795c" />
            </svg>
          </span>
          <span class="dicon__label">code.app</span>
        </button>
        <a class="dicon" href="/">
          <span class="dicon__img" aria-hidden="true">
            <svg viewBox="0 0 44 36">
              <rect x="1" y="1" width="42" height="34" fill="#fffffe" stroke="#001e1d" stroke-width="2" />
              <circle cx="17" cy="18" r="7" fill="none" stroke="#0a7489" stroke-width="4" />
              <circle cx="28" cy="18" r="7" fill="none" stroke="#c47c1d" stroke-width="4" />
            </svg>
          </span>
          <span class="dicon__label">Mode:portfolio</span>
        </a>
      </div>

      <!-- editor window（rootscion製の架空エディタ。VSCodeではなくSystem 7の書類ウィンドウ） -->
      <section class="window" id="editor-window" hidden aria-label="code editor">
        <div class="window__titlebar" id="editor-titlebar">
          <button class="wbox" data-win-close aria-label="閉じる"></button>
          <span class="window__stripes" aria-hidden="true"></span>
          <span class="window__title">code.app — portfolio</span>
          <span class="window__stripes" aria-hidden="true"></span>
          <button class="wbox wbox--zoom" data-win-max aria-label="最大化"></button>
        </div>
        <p class="window__info" aria-hidden="true">
          <span>{fileMeta.length} items</span>
          <span>2,026K in disk</span>
          <span id="status-lang">—</span>
        </p>
        <div class="window__body">
          <aside class="explorer">
            <p class="explorer__head">⌸ portfolio</p>
            {
              fileMeta.map((f) => (
                <button class="explorer__file" data-file={f.id}>
                  <span class={`doc doc--${f.dot}`} aria-hidden="true" />
                  {f.name}
                </button>
              ))
            }
          </aside>
          <div class="editor">
            <div class="tabbar" id="tabbar">
              {
                fileMeta.map((f) => (
                  <button class="tab" data-tab={f.id} hidden>
                    {f.name}
                    <span class="tab__close" data-close-tab={f.id} role="button" aria-label={`${f.name} を閉じる`}>×</span>
                  </button>
                ))
              }
            </div>
            <div class="panes">
              <!-- welcome -->
              <div class="pane pane--welcome" data-pane="welcome">
                <p class="welcome__mark" aria-hidden="true">⌸</p>
                <p>ディスク「portfolio」から書類を開いてください</p>
              </div>

              <div class="pane" data-pane="about-md" hidden>
                <div class="code">
                  {aboutLines.map((line) => <div class="code__line" set:html={line || '&nbsp;'} />)}
                </div>
              </div>
              <div class="pane" data-pane="service-ts" hidden>
                <div class="code">
                  {serviceLines.map((line) => <div class="code__line" set:html={line || '&nbsp;'} />)}
                </div>
              </div>
              <div class="pane" data-pane="skills-json" hidden>
                <div class="code">
                  {skillsLines.map((line) => <div class="code__line" set:html={line || '&nbsp;'} />)}
                </div>
              </div>
              <div class="pane" data-pane="profile-yml" hidden>
                <div class="code">
                  {profileLines.map((line) => <div class="code__line" set:html={line || '&nbsp;'} />)}
                </div>
              </div>
              <div class="pane" data-pane="works-log" hidden>
                <div class="code code--no-num">
                  {worksLines.map((line) => <div class="code__line" set:html={line || '&nbsp;'} />)}
                </div>
              </div>
              <div class="pane" data-pane="contact-sh" hidden>
                <div class="code">
                  <div class="code__line"><span class="tk-comment">#!/bin/sh</span></div>
                  <div class="code__line"><span class="tk-comment"># 「まだ相談レベル」が、いちばん歓迎です。</span></div>
                  <div class="code__line">&nbsp;</div>
                  <div class="code__line contact-line">
                    <a href="mailto:hello@rootscion.com" class="contact-link">
                      mail <span class="tk-red">--to</span> rootscion <span class="tk-green">↵</span>
                    </a>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- hint（System 7風アラート） -->
      <div class="toast" id="hint-toast" role="status">
        <strong>rootscion OS 7</strong>
        <span>code.app を開くと、ポートフォリオを閲覧できます</span>
        <button data-toast-close aria-label="閉じる">×</button>
      </div>
    </main>

    <script define:vars={{ fileMeta }}>
      /* ---- 時計 ---- */
      const clock = document.getElementById('os-clock');
      const tick = () => {
        clock.textContent = new Date().toLocaleString('ja-JP', {
          month: '2-digit', day: '2-digit', weekday: 'short',
          hour: '2-digit', minute: '2-digit',
        });
      };
      tick();
      setInterval(tick, 10_000);

      /* ---- ウィンドウの開閉・最大化 ---- */
      const win = document.getElementById('editor-window');
      const toast = document.getElementById('hint-toast');
      const langLabel = document.getElementById('status-lang');
      const langs = Object.fromEntries(fileMeta.map((f) => [f.id, f.lang]));

      const openTabs = [];
      let active = null;

      function render() {
        document.querySelectorAll('.tab').forEach((tab) => {
          const id = tab.dataset.tab;
          tab.hidden = !openTabs.includes(id);
          tab.classList.toggle('is-active', id === active);
        });
        document.querySelectorAll('.pane').forEach((pane) => {
          pane.hidden = pane.dataset.pane !== (active ?? 'welcome');
        });
        document.querySelectorAll('.explorer__file').forEach((f) => {
          f.classList.toggle('is-active', f.dataset.file === active);
        });
        langLabel.textContent = active ? langs[active] : '—';
      }

      function openFile(id) {
        if (!openTabs.includes(id)) openTabs.push(id);
        active = id;
        render();
      }

      function closeTab(id) {
        const i = openTabs.indexOf(id);
        if (i > -1) openTabs.splice(i, 1);
        if (active === id) active = openTabs[openTabs.length - 1] ?? null;
        render();
      }

      document.querySelectorAll('[data-open-editor]').forEach((btn) => {
        btn.addEventListener('click', () => {
          win.hidden = false;
          requestAnimationFrame(() => win.classList.add('is-open'));
          toast.classList.add('is-hidden');
          if (!active) openFile('about-md');
        });
      });

      document.querySelectorAll('[data-win-close]').forEach((btn) => {
        btn.addEventListener('click', () => {
          win.classList.remove('is-open', 'is-max');
          setTimeout(() => { win.hidden = true; }, 180);
        });
      });

      document.querySelector('[data-win-max]').addEventListener('click', () => {
        win.classList.toggle('is-max');
        win.style.left = '';
        win.style.top = '';
      });

      document.querySelectorAll('.explorer__file').forEach((f) => {
        f.addEventListener('click', () => openFile(f.dataset.file));
      });

      document.querySelectorAll('.tab').forEach((tab) => {
        tab.addEventListener('click', (e) => {
          if (e.target.closest('[data-close-tab]')) return;
          openFile(tab.dataset.tab);
        });
      });

      document.querySelectorAll('[data-close-tab]').forEach((x) => {
        x.addEventListener('click', (e) => {
          e.stopPropagation();
          closeTab(x.dataset.closeTab);
        });
      });

      document.querySelector('[data-toast-close]').addEventListener('click', () => {
        toast.classList.add('is-hidden');
      });

      /* ---- ウィンドウのドラッグ移動 ---- */
      const titlebar = document.getElementById('editor-titlebar');
      let dragging = false;
      let offX = 0;
      let offY = 0;

      titlebar.addEventListener('pointerdown', (e) => {
        if (e.target.closest('.wbox') || win.classList.contains('is-max')) return;
        if (window.matchMedia('(max-width: 700px)').matches) return;
        dragging = true;
        const r = win.getBoundingClientRect();
        offX = e.clientX - r.left;
        offY = e.clientY - r.top;
        titlebar.setPointerCapture(e.pointerId);
      });

      titlebar.addEventListener('pointermove', (e) => {
        if (!dragging) return;
        const x = Math.min(Math.max(e.clientX - offX, -200), innerWidth - 120);
        const y = Math.min(Math.max(e.clientY - offY, 28), innerHeight - 80);
        win.style.left = `${x}px`;
        win.style.top = `${y}px`;
        win.style.transform = 'none';
      });

      titlebar.addEventListener('pointerup', () => { dragging = false; });
    </script>

    <style is:global>
      /* Hallmark · genre: n/a (app page · retro-OS world) · design-system: design.md · designed-as-app
       * theme: cion OS 7 — Happy Hues #10 ティール深化 · System 7風チローム
       * display/chrome: DotGothic16 · code: IBM Plex Mono · prose: Noto Sans JP
       * メインサイトと配色を揃えないのは意図（モード切替の演出）。共有するのはロゴと
       * 「ハイライトだけ違う色（yellow = escの思想）」・フォーカス規律・reduced-motion
       */
      :root {
       /* 1. ベース（動画の完璧な重低音ダークネイビーを維持） */
       --os-desktop: #070a13;
        --os-desktop-dot: #1a2235;
        --os-paper: #0c1220;
        --os-paper-2: #161f33;

        /* 2. テキスト・液晶表示（【修正】シアンからライム系へ変革） */
        --os-text: #adff2f;          /* グリーンイエロー：闇の中で最も美しく発光する、有機EL調のネオンライム */
        --os-line: #39ff14;          /* ネオンライム：境界線は、よりパキッとした蛍光ライムグリーンに（不透明度を少し下げても美しい） */
        --os-dim: #416266;           /* サブテキスト：ライムの裏側に潜む、少し緑がかったダークブルーグレー */

        /* 3. アイデンティティ＆アラート（サイバーパンクの毒気を加速） */
        --os-highlight: #ff0055;     /* パステルマゼンタ：ライムの反対色である「マゼンタピンク」をここに！緑✕ピンクの組み合わせは最高にサイバーパンクになります */
        --os-focus: #fcee09;         /* サイバーイエロー：フォーカスや警告、Escキーなどのアクセントに */

        /* 4. システムカラー */
        --os-red: #ff3366;
        --os-green: #39ff14;         /* ネオンライム */
        --os-yellow: #fcee09;        /* ブランドイエロー */
        --os-blue: #00f0ff;          /* シアンはサブカラーとしてアイコン等に少し残すと深みが出ます */
        --os-purple: #9d4edd;
        --os-orange: #ff5500;

        /* 5. フォント・その他（現状の素晴らしい指定を維持） */
        --mono: 'IBM Plex Mono', monospace;
        --jp: 'Noto Sans JP', sans-serif;
        --dot: 'DotGothic16', 'IBM Plex Mono', monospace;
        --menubar-h: 28px;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      /* display指定より hidden 属性を優先させる */
      [hidden] {
        display: none !important;
      }

      body {
        font-family: var(--mono), var(--jp);
        font-size: 0.88rem;
        line-height: 1.85;
        color: var(--os-text);
        background: var(--os-desktop);
        overflow: hidden;
        height: 100svh;
        -webkit-font-smoothing: antialiased;
      }

      ::selection {
        background: rgba(249, 188, 96, 0.55);
      }

      :focus-visible {
        outline: 2px solid var(--os-focus);
        outline-offset: 2px;
      }

      /* ---- menubar（白いバー・ピクセル文字） ---- */
      .menubar {
        position: fixed;
        inset-inline: 0;
        top: 0;
        z-index: 50;
        height: var(--menubar-h);
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-inline: 0.8rem;
        background: var(--os-paper);
        border-bottom: 2px solid var(--os-line);
        font-family: var(--dot);
        font-size: 0.78rem;
        color: var(--os-line);
      }

      .menubar__left {
        display: flex;
        align-items: center;
        gap: 1rem;
      }

      .menubar__logo {
        width: 15px;
        height: 15px;
        display: block;
      }

      .menubar__left strong {
        font-weight: 400;
      }

      .menubar__menu {
        color: var(--os-dim);
      }

      .menubar__right {
        font-family: var(--dot);
      }

      /* ---- desktop（ティール＋ディザ風ドット） ---- */
      .desktop {
        position: fixed;
        inset: var(--menubar-h) 0 0;
        background:
          radial-gradient(var(--os-desktop-dot) 1px, transparent 1px) 0 0 / 4px 4px,
          var(--os-desktop);
      }

      .desktop__icons {
        position: absolute;
        top: 1.6rem;
        left: 1.6rem;
        display: flex;
        flex-direction: column;
        gap: 1.4rem;
      }

      .dicon {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
        width: 92px;
        background: none;
        border: 0;
        cursor: pointer;
        text-decoration: none;
        padding: 0.5rem 0.2rem;
      }

      .dicon__img svg {
        width: 50px;
        height: auto;
        display: block;
      }

      .dicon__label {
        font-family: var(--dot);
        font-size: 0.72rem;
        letter-spacing: 0.04em;
        color: var(--os-line);
        padding: 0.05rem 0.35rem;
      }

      .dicon:hover .dicon__label,
      .dicon:focus-visible .dicon__label {
        background: var(--os-highlight);
        color: var(--os-line);
      }

      /* ---- window（角ばった書類ウィンドウ・ハードシャドウ） ---- */
      .window {
        position: fixed;
        left: 50%;
        top: 54%;
        transform: translate(-50%, -50%) scale(0.98);
        width: min(920px, 94vw);
        height: min(620px, 80vh);
        display: flex;
        flex-direction: column;
        background: var(--os-paper);
        border: 2px solid var(--os-line);
        box-shadow: 4px 4px 0 rgba(0, 30, 29, 0.45);
        opacity: 0;
        transition: opacity 0.18s ease-out, transform 0.18s ease-out;
        overflow: hidden;
      }

      .window.is-open {
        opacity: 1;
        transform: translate(-50%, -50%) scale(1);
      }

      .window.is-open[style*='left'] {
        transform: none;
      }

      .window.is-max {
        inset: var(--menubar-h) 8px 8px !important;
        width: auto;
        height: auto;
        transform: none !important;
      }

      /* ---- titlebar（横ストライプ＋中央タイトル＋左クローズ/右ズームの四角） ---- */
      .window__titlebar {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        height: 30px;
        padding-inline: 0.55rem;
        background: var(--os-paper);
        border-bottom: 2px solid var(--os-line);
        cursor: grab;
        user-select: none;
        touch-action: none;
        flex-shrink: 0;
      }

      .window__titlebar:active {
        cursor: grabbing;
      }

      .window__stripes {
        flex: 1;
        height: 13px;
        background: repeating-linear-gradient(
          to bottom,
          var(--os-line) 0 1px,
          transparent 1px 3px
        );
        min-width: 12px;
      }

      .window__title {
        font-family: var(--dot);
        font-size: 0.8rem;
        color: var(--os-line);
        letter-spacing: 0.05em;
        white-space: nowrap;
      }

      .wbox {
        width: 14px;
        height: 14px;
        flex-shrink: 0;
        background: var(--os-paper);
        border: 2px solid var(--os-line);
        cursor: pointer;
        padding: 0;
      }

      .wbox:hover {
        background: var(--os-highlight);
      }

      .wbox--zoom {
        position: relative;
      }

      .wbox--zoom::after {
        content: '';
        position: absolute;
        inset: 0;
        border-right: 2px solid var(--os-line);
        border-bottom: 2px solid var(--os-line);
        width: 55%;
        height: 55%;
      }

      /* ---- info bar（Finderの「6 items, XXK available」風） ---- */
      .window__info {
        display: flex;
        justify-content: center;
        gap: 1.6rem;
        padding: 0.18rem 0.9rem;
        background: var(--os-paper-2);
        border-bottom: 2px solid var(--os-line);
        font-family: var(--dot);
        font-size: 0.72rem;
        color: var(--os-text);
        flex-shrink: 0;
      }

      .window__body {
        flex: 1;
        display: flex;
        min-height: 0;
      }

      /* ---- explorer → ディスクのリストビュー ---- */
      .explorer {
        width: 172px;
        flex-shrink: 0;
        background: var(--os-paper);
        border-right: 2px solid var(--os-line);
        padding: 0.6rem 0;
        overflow-y: auto;
      }

      .explorer__head {
        font-family: var(--dot);
        font-size: 0.74rem;
        color: var(--os-line);
        padding: 0 0.9rem 0.4rem;
        border-bottom: 1px dotted var(--os-dim);
        margin-bottom: 0.4rem;
      }

      .explorer__file {
        display: flex;
        align-items: center;
        gap: 0.55rem;
        width: 100%;
        padding: 0.3rem 0.9rem;
        background: none;
        border: 0;
        color: var(--os-text);
        font-family: var(--mono);
        font-size: 0.76rem;
        cursor: pointer;
        text-align: left;
      }

      .explorer__file:hover {
        background: var(--os-paper-2);
      }

      .explorer__file:active,
      .tab:active,
      .dicon:active,
      .wbox:active {
        background: var(--os-highlight);
      }

      .explorer__file.is-active {
        background: var(--os-line);
        color: var(--os-paper);
      }

      /* ピクセル書類アイコン（折り目付き） */
      .doc {
        width: 10px;
        height: 12px;
        flex-shrink: 0;
        border: 1px solid currentColor;
        position: relative;
        background: linear-gradient(135deg, transparent 0 3px, var(--doc-color, currentColor) 3px 5px, transparent 5px);
      }

      .doc::after {
        content: '';
        position: absolute;
        left: 1px;
        right: 1px;
        bottom: 2px;
        height: 1px;
        background: var(--doc-color, currentColor);
      }

      .doc--md { --doc-color: var(--os-blue); }
      .doc--ts { --doc-color: var(--os-blue); }
      .doc--json { --doc-color: var(--os-orange); }
      .doc--yml { --doc-color: var(--os-red); }
      .doc--log { --doc-color: var(--os-green); }
      .doc--sh { --doc-color: var(--os-purple); }

      .explorer__file.is-active .doc {
        background: linear-gradient(135deg, transparent 0 3px, var(--os-paper) 3px 5px, transparent 5px);
      }

      .explorer__file.is-active .doc::after {
        background: var(--os-paper);
      }

      /* ---- editor ---- */
      .editor {
        flex: 1;
        display: flex;
        flex-direction: column;
        min-width: 0;
      }

      /* ---- tabbar → System 7のフォルダタブ ---- */
      .tabbar {
        display: flex;
        gap: 4px;
        padding: 6px 8px 0;
        background: var(--os-paper-2);
        border-bottom: 2px solid var(--os-line);
        overflow-x: auto;
        flex-shrink: 0;
      }

      .tab {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.28rem 0.7rem;
        background: var(--os-paper-2);
        border: 2px solid var(--os-line);
        border-bottom: 0;
        margin-bottom: -2px;
        color: var(--os-dim);
        font-family: var(--dot);
        font-size: 0.74rem;
        cursor: pointer;
        white-space: nowrap;
      }

      .tab.is-active {
        background: var(--os-paper);
        color: var(--os-line);
        position: relative;
        z-index: 1;
      }

      .tab__close {
        opacity: 0.5;
        padding-inline: 0.15rem;
      }

      .tab__close:hover {
        opacity: 1;
        color: var(--os-red);
      }

      /* ---- panes / code ---- */
      .panes {
        flex: 1;
        overflow: auto;
        min-height: 0;
        background: var(--os-paper);
      }

      .pane--welcome {
        height: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 0.8rem;
        color: var(--os-dim);
        font-size: 0.8rem;
        font-family: var(--jp);
      }

      .welcome__mark {
        font-family: var(--dot);
        font-size: 2.4rem;
        line-height: 1;
        color: var(--os-text);
      }

      .code {
        padding: 1.1rem 0;
        counter-reset: ln;
      }

      .code__line {
        padding-inline: 1rem;
        white-space: pre-wrap;
        word-break: break-word;
        font-size: 0.82rem;
      }

      .code:not(.code--no-num) .code__line {
        counter-increment: ln;
        padding-left: 3.4rem;
        position: relative;
      }

      .code:not(.code--no-num) .code__line::before {
        content: counter(ln);
        position: absolute;
        left: 0;
        width: 2.3rem;
        text-align: right;
        color: var(--os-dim);
        font-size: 0.72rem;
        user-select: none;
      }

      /* tokens */
      .tk-blue { color: var(--os-blue); }
      .tk-green { color: var(--os-green); }
      .tk-red { color: var(--os-red); }
      .tk-purple { color: var(--os-purple); }
      .tk-orange { color: var(--os-orange); }
      .tk-str { color: var(--os-green); }
      .tk-comment { color: var(--os-dim); font-style: italic; }
      .tk-bold { font-weight: 700; color: var(--os-line); }

      .code .tk-link {
        color: var(--os-blue);
        text-underline-offset: 3px;
      }

      /* contact.sh */
      .contact-line { padding-block: 0.6rem; }

      .contact-link {
        font-size: clamp(1.3rem, 4vw, 2rem);
        font-weight: 700;
        color: var(--os-line);
        text-decoration: none;
      }

      .contact-link:hover { color: var(--os-blue); }

      /* ---- toast（System 7風アラート） ---- */
      .toast {
        position: absolute;
        top: 1.2rem;
        right: 1.2rem;
        display: flex;
        align-items: center;
        gap: 0.7rem;
        padding: 0.7rem 1rem;
        background: var(--os-paper);
        border: 2px solid var(--os-line);
        box-shadow: 3px 3px 0 rgba(0, 30, 29, 0.45);
        font-size: 0.74rem;
        font-family: var(--jp);
        animation: toast-in 0.5s ease-out 0.8s backwards;
        max-width: min(340px, 84vw);
      }

      .toast strong {
        color: var(--os-line);
        font-family: var(--dot);
        font-size: 0.74rem;
        font-weight: 400;
      }

      .toast button {
        background: none;
        border: 0;
        color: var(--os-dim);
        cursor: pointer;
        font-size: 0.9rem;
      }

      .toast.is-hidden {
        display: none;
      }

      @keyframes toast-in {
        from { opacity: 0; transform: translateY(-8px); }
      }

      /* ---- mobile ---- */
      @media (max-width: 700px) {
        .menubar__menu {
          display: none;
        }

        .menubar__left {
          gap: 0.6rem;
        }

        .window,
        .window.is-open {
          /* ドラッグで付くインラインの left/top も !important で打ち消して全面表示にする */
          inset: var(--menubar-h) 0 0 !important;
          width: auto;
          height: auto;
          transform: none !important;
          box-shadow: none;
        }

        .window__body {
          flex-direction: column;
        }

        .explorer {
          width: auto;
          display: flex;
          align-items: center;
          gap: 0.2rem;
          padding: 0.4rem 0.6rem;
          border-right: 0;
          border-bottom: 2px solid var(--os-line);
          overflow-x: auto;
        }

        .explorer__head {
          display: none;
        }

        .explorer__file {
          width: auto;
          padding: 0.3rem 0.6rem;
          white-space: nowrap;
        }

        .window__info {
          gap: 1rem;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        .window {
          transition: opacity 150ms linear;
        }
        .toast {
          animation: none;
        }
      }
    </style>
  </body>
</html>
