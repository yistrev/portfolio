---
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'reproots — 要件定義からフロントエンド実装、チームマネジメントまで並走する Web Engineer / Technical Director のポートフォリオサイト',
} = Astro.props;

const year = new Date().getFullYear();
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Zen+Kaku+Gothic+New:wght@400;500;700&family=Elms+Sans:wght@100..900&family=Geist+Mono&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <!-- 追従ヘッダー: ロゴ左・モード切替＋キーキャップ型メニュートリガー右 -->
    <header class="site-header">
      <div class="site-header__inner">
        <a href="/" class="site-header__logo">
          <img src="/logo.svg" alt="reproots" class="logo-wordmark" width="761" height="220" />
        </a>
        <div class="site-header__right">
          <a href="/engineer" class="site-header__mode">Mode: engineer →</a>
          <button
            class="menu-toggle"
            data-menu-toggle
            aria-expanded="false"
            aria-controls="site-menu"
            aria-label="メニューを開く"
          >≡</button>
        </div>
      </div>
    </header>

    <!-- 開閉メニュー（閉じるキーは esc） -->
    <div class="menu" id="site-menu" hidden>
      <div class="menu__inner">
        <div class="menu__top">
          <span class="menu__brand">reproots — index</span>
          <button class="menu__esc" data-menu-close aria-label="メニューを閉じる">esc</button>
        </div>
        <nav class="menu__nav" aria-label="サイト内メニュー">
          <a href="/#about"><span class="idx">01</span>About</a>
          <a href="/#process"><span class="idx">02</span>Process</a>
          <a href="/#skills"><span class="idx">03</span>Specs</a>
          <a href="/#profile"><span class="idx">04</span>Profile</a>
          <a href="/#contact"><span class="idx">05</span>Contact</a>
        </nav>
        <p class="menu__meta">
          <a href="https://github.com/yistrev" target="_blank" rel="noopener">GitHub →</a>
          <a href="/engineer">Mode: engineer →</a>
        </p>
      </div>
    </div>

    <!-- 方眼紙の上を追跡する計測円（レティクル）。本文の背面に固定 -->
    <div class="tracker" aria-hidden="true"></div>

    <slot />

    <!-- Ft4 dense colophon: 索引・クレジット・ビルド情報をひとつの銘板ブロックで -->
    <footer class="site-footer">
      <p class="colophon">
        <span class="stripes" aria-hidden="true"></span>Unit R-{year}. &copy; {year} reproots.
        <span class="dim">
          <a href="/engineer">Mode: engineer</a>
        </span>
      </p>
    </footer>
    <script>
      import gsap from 'gsap';

      const toggle = document.querySelector('[data-menu-toggle]');
      const menu = document.getElementById('site-menu');
      const closeBtn = menu.querySelector('[data-menu-close]');
      const items = menu.querySelectorAll('.menu__nav a');
      const meta = menu.querySelector('.menu__meta');
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      let isOpen = false;

      function openMenu() {
        isOpen = true;
        menu.hidden = false;
        toggle.setAttribute('aria-expanded', 'true');
        document.body.classList.add('menu-open');
        if (!reduceMotion) {
          gsap.fromTo(menu, { autoAlpha: 0 }, { autoAlpha: 1, duration: 0.28, ease: 'power2.out' });
          gsap.fromTo(items,
            { yPercent: 70, autoAlpha: 0 },
            { yPercent: 0, autoAlpha: 1, duration: 0.55, stagger: 0.06, ease: 'expo.out', delay: 0.08 }
          );
          gsap.fromTo(meta, { autoAlpha: 0, y: 14 }, { autoAlpha: 1, y: 0, duration: 0.4, ease: 'power2.out', delay: 0.3 });
        }
        closeBtn.focus();
      }

      function closeMenu() {
        isOpen = false;
        toggle.setAttribute('aria-expanded', 'false');
        document.body.classList.remove('menu-open');
        if (!reduceMotion) {
          gsap.to(menu, {
            autoAlpha: 0,
            duration: 0.22,
            ease: 'power2.in',
            onComplete: () => {
              menu.hidden = true;
              gsap.set([menu, items, meta], { clearProps: 'all' });
            },
          });
        } else {
          menu.hidden = true;
        }
        toggle.focus();
      }

      toggle.addEventListener('click', () => (isOpen ? closeMenu() : openMenu()));
      closeBtn.addEventListener('click', closeMenu);

      // 世界観どおり esc キーでも閉じる
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && isOpen) closeMenu();
      });

      // アンカー遷移時は即座に閉じる（スクロール先が見えるように）
      items.forEach((a) => {
        a.addEventListener('click', () => {
          isOpen = false;
          toggle.setAttribute('aria-expanded', 'false');
          document.body.classList.remove('menu-open');
          menu.hidden = true;
          gsap.set([menu, items, meta], { clearProps: 'all' });
        });
      });
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
